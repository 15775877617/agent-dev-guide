    {"type": "text", "id": "note1", "x": 50, "y": 350, "width": 500, "height": 50, "text": "window_size=4: pack [N-4 .. N+4] = 9 sentences\nfor each target sentence as metadata", "fontSize": 16, "fontFamily": 1, "strokeColor": "#757575", "originalText": "window_size=4: pack [N-4 .. N+4] = 9 sentences\nfor each target sentence as metadata", "autoResize": true}
